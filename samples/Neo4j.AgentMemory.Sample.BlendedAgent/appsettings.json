{
  // Neo4j connection settings
  "Neo4j": {
    "Uri":      "bolt://localhost:7687",
    "Username": "neo4j",
    "Password": "your-password-here",

    // GraphRAG index configuration.
    // The vector index must exist in Neo4j before running this sample.
    //
    // To create a vector index in Neo4j Browser / cypher-shell:
    //   CREATE VECTOR INDEX knowledge_vectors IF NOT EXISTS
    //   FOR (n:KnowledgeChunk) ON (n.embedding)
    //   OPTIONS { indexConfig: { `vector.dimensions`: 1536, `vector.similarity_function`: 'cosine' } };
    //
    // To create a fulltext index:
    //   CREATE FULLTEXT INDEX knowledge_vectors_fulltext IF NOT EXISTS
    //   FOR (n:KnowledgeChunk) ON EACH [n.text];
    "GraphRag": {
      "IndexName":         "knowledge_vectors",
      "FulltextIndexName": "knowledge_vectors_fulltext"
    }
  },

  "Logging": {
    "LogLevel": {
      "Default":             "Information",
      "Neo4j.AgentMemory":   "Debug"
    }
  }
}
