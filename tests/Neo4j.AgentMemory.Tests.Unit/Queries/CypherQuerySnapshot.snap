## ReasoningQueries.UpdateTrace
MATCH (t:ReasoningTrace {id: $id})
            SET
                t.task         = $task,
                t.outcome      = $outcome,
                t.success      = $success,
                t.started_at   = datetime($startedAt),
                t.completed_at = CASE WHEN $completedAt IS NOT NULL THEN datetime($completedAt) ELSE null END,
                t.metadata     = $metadata
            RETURN t

## RelationshipQueries.GetByEntity
MATCH (s:Entity)-[r:RELATED_TO]->(t:Entity)
            WHERE s.id = $entityId OR t.id = $entityId
            RETURN r

## RelationshipQueries.GetById
MATCH ()-[r:RELATED_TO {id: $id}]->() RETURN r

## RelationshipQueries.GetBySourceEntity
MATCH (s:Entity {id: $sourceEntityId})-[r:RELATED_TO]->() RETURN r

## RelationshipQueries.GetByTargetEntity
MATCH ()-[r:RELATED_TO]->(t:Entity {id: $targetEntityId}) RETURN r

## RelationshipQueries.Upsert
MERGE (s:Entity {id: $sourceEntityId})
            MERGE (t:Entity {id: $targetEntityId})
            MERGE (s)-[r:RELATED_TO {id: $id}]->(t)
            ON CREATE SET
                r.relation_type      = $relationType,
                r.source_entity_id   = $sourceEntityId,
                r.target_entity_id   = $targetEntityId,
                r.confidence         = $confidence,
                r.description        = $description,
                r.valid_from         = CASE WHEN $validFrom IS NOT NULL THEN datetime($validFrom) ELSE null END,
                r.valid_until        = CASE WHEN $validUntil IS NOT NULL THEN datetime($validUntil) ELSE null END,
                r.attributes         = $attributes,
                r.source_message_ids = $sourceMessageIds,
                r.created_at         = datetime($createdAt),
                r.updated_at         = datetime($updatedAt),
                r.metadata           = $metadata
            ON MATCH SET
                r.relation_type      = $relationType,
                r.confidence         = $confidence,
                r.description        = $description,
                r.valid_from         = CASE WHEN $validFrom IS NOT NULL THEN datetime($validFrom) ELSE null END,
                r.valid_until        = CASE WHEN $validUntil IS NOT NULL THEN datetime($validUntil) ELSE null END,
                r.attributes         = $attributes,
                r.source_message_ids = $sourceMessageIds,
                r.updated_at         = datetime($updatedAt),
                r.metadata           = $metadata
            RETURN r

## SchemaQueries.ConversationIdConstraint
CREATE CONSTRAINT conversation_id IF NOT EXISTS FOR (c:Conversation) REQUIRE c.id IS UNIQUE

## SchemaQueries.ConversationSessionIndex
CREATE INDEX conversation_session_idx IF NOT EXISTS FOR (c:Conversation) ON (c.session_id)

## SchemaQueries.EntityCanonicalIndex
CREATE INDEX entity_canonical_idx IF NOT EXISTS FOR (e:Entity) ON (e.canonical_name)

## SchemaQueries.EntityIdConstraint
CREATE CONSTRAINT entity_id IF NOT EXISTS FOR (e:Entity) REQUIRE e.id IS UNIQUE

## SchemaQueries.EntityLocationIndex
CREATE POINT INDEX entity_location_idx IF NOT EXISTS FOR (e:Entity) ON (e.location)

## SchemaQueries.EntityNameFulltext
CREATE FULLTEXT INDEX entity_name IF NOT EXISTS FOR (e:Entity) ON EACH [e.name, e.description]

## SchemaQueries.EntityNameIndex
CREATE INDEX entity_name_idx IF NOT EXISTS FOR (e:Entity) ON (e.name)

## SchemaQueries.EntityTypeIndex
CREATE INDEX entity_type_idx IF NOT EXISTS FOR (e:Entity) ON (e.type)

## SchemaQueries.ExtractorNameConstraint
CREATE CONSTRAINT extractor_name IF NOT EXISTS FOR (ex:Extractor) REQUIRE ex.name IS UNIQUE

## SchemaQueries.FactCategoryIndex
CREATE INDEX fact_category IF NOT EXISTS FOR (f:Fact) ON (f.category)

## SchemaQueries.FactContentFulltext
CREATE FULLTEXT INDEX fact_content IF NOT EXISTS FOR (f:Fact) ON EACH [f.subject, f.predicate, f.object]

## SchemaQueries.FactIdConstraint
CREATE CONSTRAINT fact_id IF NOT EXISTS FOR (f:Fact) REQUIRE f.id IS UNIQUE

## SchemaQueries.IsMigrationApplied
MATCH (m:Migration {version: $version}) RETURN m LIMIT 1

## SchemaQueries.MessageContentFulltext
CREATE FULLTEXT INDEX message_content IF NOT EXISTS FOR (m:Message) ON EACH [m.content]

## SchemaQueries.MessageIdConstraint
CREATE CONSTRAINT message_id IF NOT EXISTS FOR (m:Message) REQUIRE m.id IS UNIQUE

## SchemaQueries.MessageRoleIndex
CREATE INDEX message_role_idx IF NOT EXISTS FOR (m:Message) ON (m.role)

## SchemaQueries.MessageTimestampIndex
CREATE INDEX message_timestamp_idx IF NOT EXISTS FOR (m:Message) ON (m.timestamp)

## SchemaQueries.MigrationVersionConstraint
CREATE CONSTRAINT migration_version IF NOT EXISTS FOR (m:Migration) REQUIRE m.version IS UNIQUE

## SchemaQueries.PreferenceCategoryIndex
CREATE INDEX preference_category_idx IF NOT EXISTS FOR (p:Preference) ON (p.category)

## SchemaQueries.PreferenceIdConstraint
CREATE CONSTRAINT preference_id IF NOT EXISTS FOR (p:Preference) REQUIRE p.id IS UNIQUE

## SchemaQueries.ReasoningStepIdConstraint
CREATE CONSTRAINT reasoning_step_id IF NOT EXISTS FOR (s:ReasoningStep) REQUIRE s.id IS UNIQUE

## SchemaQueries.ReasoningStepTimestampIndex
CREATE INDEX reasoning_step_timestamp IF NOT EXISTS FOR (s:ReasoningStep) ON (s.timestamp)

## SchemaQueries.ReasoningTraceIdConstraint
CREATE CONSTRAINT reasoning_trace_id IF NOT EXISTS FOR (t:ReasoningTrace) REQUIRE t.id IS UNIQUE

## SchemaQueries.RecordMigration
MERGE (m:Migration {version: $version}) SET m.appliedAtUtc = $appliedAtUtc

## SchemaQueries.SchemaNameIndex
CREATE INDEX schema_name_idx IF NOT EXISTS FOR (s:Schema) ON (s.name)

## SchemaQueries.SchemaVersionIndex
CREATE INDEX schema_version_idx IF NOT EXISTS FOR (s:Schema) ON (s.version)

## SchemaQueries.ToolCallIdConstraint
CREATE CONSTRAINT tool_call_id IF NOT EXISTS FOR (tc:ToolCall) REQUIRE tc.id IS UNIQUE

## SchemaQueries.ToolCallStatusIndex
CREATE INDEX tool_call_status_idx IF NOT EXISTS FOR (tc:ToolCall) ON (tc.status)

## SchemaQueries.ToolNameConstraint
CREATE CONSTRAINT tool_name IF NOT EXISTS FOR (t:Tool) REQUIRE t.name IS UNIQUE

## SchemaQueries.TraceSessionIndex
CREATE INDEX trace_session_idx IF NOT EXISTS FOR (t:ReasoningTrace) ON (t.session_id)

## SchemaQueries.TraceSuccessIndex
CREATE INDEX trace_success_idx IF NOT EXISTS FOR (t:ReasoningTrace) ON (t.success)

## TemporalQueries.GetEntityByIdAsOf
MATCH (e:Entity {id: $id})
            WHERE e.created_at <= datetime($asOf)
              AND (e.invalidated_at IS NULL OR e.invalidated_at > datetime($asOf))
            RETURN e

## TemporalQueries.GetFactByIdAsOf
MATCH (f:Fact {id: $id})
            WHERE f.created_at <= datetime($asOf)
              AND (f.invalidated_at IS NULL OR f.invalidated_at > datetime($asOf))
              AND (f.valid_from IS NULL OR f.valid_from <= datetime($asOf))
              AND (f.valid_until IS NULL OR f.valid_until > datetime($asOf))
            RETURN f

## TemporalQueries.GetPreferenceByIdAsOf
MATCH (p:Preference {id: $id})
            WHERE p.created_at <= datetime($asOf)
              AND (p.invalidated_at IS NULL OR p.invalidated_at > datetime($asOf))
            RETURN p

## TemporalQueries.GetRecentMessagesAsOf
MATCH (m:Message {session_id: $sessionId})
            WHERE m.timestamp <= datetime($asOf)
            RETURN m
            ORDER BY m.timestamp DESC
            LIMIT $limit

## TemporalQueries.SearchEntitiesAsOf
CALL db.index.vector.queryNodes('entity_embedding_idx', $limit, $embedding)
            YIELD node, score
            WHERE score >= $minScore
              AND node.created_at <= datetime($asOf)
              AND (node.invalidated_at IS NULL OR node.invalidated_at > datetime($asOf))
            RETURN node, score
            ORDER BY score DESC

## TemporalQueries.SearchFactsAsOf
CALL db.index.vector.queryNodes('fact_embedding_idx', $limit, $embedding)
            YIELD node, score
            WHERE score >= $minScore
              AND node.created_at <= datetime($asOf)
              AND (node.invalidated_at IS NULL OR node.invalidated_at > datetime($asOf))
              AND (node.valid_from IS NULL OR node.valid_from <= datetime($asOf))
              AND (node.valid_until IS NULL OR node.valid_until > datetime($asOf))
            RETURN node, score
            ORDER BY score DESC

## TemporalQueries.SearchPreferencesAsOf
CALL db.index.vector.queryNodes('preference_embedding_idx', $limit, $embedding)
            YIELD node, score
            WHERE score >= $minScore
              AND node.created_at <= datetime($asOf)
              AND (node.invalidated_at IS NULL OR node.invalidated_at > datetime($asOf))
            RETURN node, score
            ORDER BY score DESC

## ToolCallQueries.Add
MATCH (s:ReasoningStep {id: $stepId})
            CREATE (tc:ToolCall {
                id:          $id,
                step_id:     $stepId,
                tool_name:   $toolName,
                arguments:   $arguments,
                result:      $result,
                status:      $status,
                duration_ms: $durationMs,
                error:       $error,
                metadata:    $metadata,
                timestamp:   datetime()
            })
            CREATE (s)-[:USES_TOOL]->(tc)
            RETURN tc

## ToolCallQueries.CreateTriggeredByRelationship
MATCH (tc:ToolCall {id: $toolCallId}), (m:Message {id: $messageId})
                MERGE (tc)-[:TRIGGERED_BY]->(m)

## ToolCallQueries.GetById
MATCH (tc:ToolCall {id: $id}) RETURN tc

## ToolCallQueries.GetByStep
MATCH (s:ReasoningStep {id: $stepId})-[:USES_TOOL]->(tc:ToolCall)
            RETURN tc
            ORDER BY tc.tool_name

## ToolCallQueries.Update
MATCH (tc:ToolCall {id: $id})
            SET
                tc.tool_name   = $toolName,
                tc.arguments   = $arguments,
                tc.result      = $result,
                tc.status      = $status,
                tc.duration_ms = $durationMs,
                tc.error       = $error,
                tc.metadata    = $metadata
            RETURN tc

## ToolCallQueries.UpsertToolInstance
MATCH (tc:ToolCall {id: $id})
                MERGE (tool:Tool {name: $toolName})
                ON CREATE SET tool.created_at = datetime(),
                              tool.description = $description,
                              tool.total_calls = 0,
                              tool.successful_calls = 0,
                              tool.failed_calls = 0,
                              tool.total_duration_ms = 0
                MERGE (tc)-[:INSTANCE_OF]->(tool)
                SET tool.total_calls = COALESCE(tool.total_calls, 0) + 1,
                    tool.successful_calls = COALESCE(tool.successful_calls, 0) + CASE WHEN $status = 'success' THEN 1 ELSE 0 END,
                    tool.failed_calls = COALESCE(tool.failed_calls, 0) + CASE WHEN $status IN ['error', 'failure', 'timeout'] THEN 1 ELSE 0 END,
                    tool.total_duration_ms = COALESCE(tool.total_duration_ms, 0) + COALESCE($durationMs, 0),
                    tool.last_used_at = datetime()

