            WHERE score >= $minScore
            RETURN node, score
            ORDER BY score DESC

## EntityQueries.SearchInBoundingBox
MATCH (e:Entity)
            WHERE e.location IS NOT NULL
              AND point.withinBBox(
                    e.location,
                    point({longitude: $minLon, latitude: $minLat}),
                    point({longitude: $maxLon, latitude: $maxLat}))
            RETURN e
            LIMIT $limit

