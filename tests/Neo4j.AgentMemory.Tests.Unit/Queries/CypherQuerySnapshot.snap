MATCH (s:ReasoningStep {id: $id}) RETURN s

## ReasoningQueries.GetStepsByTrace
MATCH (t:ReasoningTrace {id: $traceId})-[:HAS_STEP]->(s:ReasoningStep)
            RETURN s
            ORDER BY s.step_number

## ReasoningQueries.GetTraceById
MATCH (t:ReasoningTrace {id: $id}) RETURN t

