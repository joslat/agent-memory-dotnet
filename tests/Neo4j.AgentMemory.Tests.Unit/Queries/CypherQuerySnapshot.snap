MATCH (t:ReasoningTrace {session_id: $sessionId})
            RETURN t
            ORDER BY t.started_at DESC
            LIMIT $limit

## ReasoningQueries.SetStepEmbedding
MATCH (s:ReasoningStep {id: $id}) SET s.embedding = $embedding

